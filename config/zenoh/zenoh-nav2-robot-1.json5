// Zenoh client for robot_1's Nav2 pod.
// No ros_namespace (not supported in zenoh-bridge-ros2dds 1.9.0).
// topic_relay.py inside the pod bridges /robot_1/* ↔ bare topic names.
// The allow filter routes only /robot_1/* topics plus shared topics.
{
  mode: "client",
  connect: { endpoints: ["tcp/zenoh-router:7447"] },
  scouting: { multicast: { enabled: false } },
  plugins: {
    ros2dds: {
      allow: "^/(robot_1/(scan|odom|imu|joint_states|cmd_vel|tf|tf_static|map|plan|robot_description)|clock|ros_discovery_info|rosout)$"
    }
  }
}
