// Zenoh client for robot_1's Nav2 pod.
// namespace: "/robot_1" prefixes all bridged topics in Zenoh, so SLAM/Nav2 see
// bare /scan, /odom etc. locally while Zenoh carries ros2/robot_1/scan etc.
{
  mode: "client",
  connect: { endpoints: ["tcp/zenoh-router:7447"] },
  scouting: { multicast: { enabled: false } },
  plugins: {
    ros2dds: {
      namespace: "/robot_1",
      allow: "^(scan|odom|imu|joint_states|cmd_vel|tf|tf_static|map|plan|clock|ros_discovery_info|rosout)$"
    }
  }
}
