// Zenoh client for robot_2's Nav2 pod.
// namespace: "/robot_2" prefixes all bridged topics in Zenoh.
{
  mode: "client",
  connect: { endpoints: ["tcp/zenoh-router:7447"] },
  scouting: { multicast: { enabled: false } },
  plugins: {
    ros2dds: {
      namespace: "/robot_2",
      allow: "^(scan|odom|imu|joint_states|cmd_vel|tf|tf_static|map|plan|clock|ros_discovery_info|rosout)$"
    }
  }
}
